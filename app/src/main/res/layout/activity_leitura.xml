<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="match_parent"

    android:background="@drawable/bg_leitura">


    <LinearLayout
        android:id="@+id/header"

        android:layout_width="match_parent"
        android:layout_height="90dp"

        android:background="#0B0B0B"

        android:orientation="horizontal"
        android:gravity="center_vertical"

        android:paddingStart="16dp"
        android:paddingEnd="16dp"

        app:layout_constraintTop_toTopOf="parent">


        <ImageButton
            android:id="@+id/btnVoltar"

            android:layout_width="45dp"
            android:layout_height="45dp"

            android:background="@drawable/bg_botao"
            android:src="@drawable/ic_voltar"/>


        <ImageView
            android:id="@+id/imgLogo"

            android:layout_width="0dp"
            android:layout_height="50dp"

            android:layout_weight="1"

            android:layout_marginStart="20dp"
            android:layout_marginEnd="45dp"

            android:src="@drawable/logo_progressa"

            android:scaleType="fitCenter"/>

    </LinearLayout>


    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerLeitura"

        android:layout_width="match_parent"
        android:layout_height="0dp"

        android:paddingTop="40dp"

        android:clipToPadding="false"

        app:layout_constraintTop_toBottomOf="@id/header"

        app:layout_constraintBottom_toTopOf="@id/btnNovoLivro"/>


    <Button
        android:id="@+id/btnNovoLivro"

        android:layout_width="220dp"
        android:layout_height="55dp"

        android:text="+ Adicionar Livro"

        android:textColor="#FFFFFF"

        android:background="@drawable/bg_botao"

        android:layout_marginBottom="20dp"

        app:layout_constraintBottom_toBottomOf="parent"

        app:layout_constraintStart_toStartOf="parent"

        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>