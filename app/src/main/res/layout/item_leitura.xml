<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    android:orientation="vertical"
    android:padding="18dp"
    android:background="@drawable/bg_card_leitura">

    <TextView
        android:id="@+id/txtLivro"
        android:text="📚 Dom Casmurro"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>


    <TextView
        android:id="@+id/txtAutor"
        android:text="👤 Machado de Assis"
        android:textColor="#FFFFFF"
        android:layout_marginTop="10dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>


    <TextView
        android:id="@+id/txtPrevisao"
        android:text="📅 29/12/2025"
        android:textColor="#FFFFFF"
        android:layout_marginTop="5dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>


    <TextView
        android:id="@+id/txtPagina"
        android:text="📖 Página 120/208"
        android:textColor="#FFFFFF"
        android:layout_marginTop="5dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>


    <ProgressBar
        android:id="@+id/progressLeitura"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="12dp"
        android:layout_marginTop="14dp"
        android:max="100"
        android:progress="50"/>


    <TextView
        android:id="@+id/txtAnotacao"
        android:text="📝 observação"
        android:textColor="#FFFFFF"
        android:layout_marginTop="15dp"
        android:background="#33000000"
        android:padding="12dp"
        android:layout_width="match_parent"
        android:layout_height="80dp"/>


    <LinearLayout
        android:layout_marginTop="15dp"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">


        <Button
            android:id="@+id/btnEditar"
            android:text="✏️"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"/>


        <Button
            android:id="@+id/btnExcluir"
            android:text="🗑️"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"/>

    </LinearLayout>

</LinearLayout>