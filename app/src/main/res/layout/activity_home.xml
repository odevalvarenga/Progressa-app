<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login">

    <!-- Ícone de Menu (Topo Direito) -->
    <ImageButton
        android:id="@+id/btnMenu"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Menu"
        android:src="@drawable/ic_menu"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#FFFFFF" />

    <!-- Foto de Perfil Circular -->
    <FrameLayout
        android:id="@+id/profileContainer"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_marginTop="60dp"
        android:background="@drawable/bg_circle_profile"
        android:backgroundTint="#408B5CF6"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="85dp"
            android:layout_height="85dp"
            android:layout_gravity="center"
            android:contentDescription="Foto de perfil"
            android:src="@drawable/ic_pessoa"
            app:tint="#FFFFFF" />
    </FrameLayout>

    <!-- Texto de Boas-vindas -->
    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Olá Noah"
        android:textColor="#FFFFFF"
        android:textSize="36sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/profileContainer" />

    <!-- Localização -->
    <LinearLayout
        android:id="@+id/llLocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvWelcome">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="Ícone Localização"
            android:src="@drawable/ic_location"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="São Paulo, SP"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Linha Divisória -->
    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginStart="50dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="50dp"
        android:background="#60FFFFFF"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llLocation" />

    <!-- Grid de Opções (6 cards) -->
    <LinearLayout
        android:id="@+id/gridContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider">

        <!-- Primeira Linha -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
            <LinearLayout android:layout_width="95dp" android:layout_height="105dp" android:layout_margin="8dp" android:background="@drawable/bg_home_card" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="36dp" android:layout_height="36dp" android:src="@drawable/ic_materias" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Matérias" android:textColor="#FFFFFF" android:textSize="13sp" />
            </LinearLayout>
            <LinearLayout android:layout_width="95dp" android:layout_height="105dp" android:layout_margin="8dp" android:background="@drawable/bg_home_card" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="36dp" android:layout_height="36dp" android:src="@drawable/ic_leitura" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Leitura" android:textColor="#FFFFFF" android:textSize="13sp" />
            </LinearLayout>
            <LinearLayout android:layout_width="95dp" android:layout_height="105dp" android:layout_margin="8dp" android:background="@drawable/bg_home_card" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="36dp" android:layout_height="36dp" android:src="@drawable/ic_hidratacao" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Hidratação" android:textColor="#FFFFFF" android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Segunda Linha -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
            <LinearLayout android:layout_width="95dp" android:layout_height="105dp" android:layout_margin="8dp" android:background="@drawable/bg_home_card" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="36dp" android:layout_height="36dp" android:src="@drawable/ic_boletim" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Boletim" android:textColor="#FFFFFF" android:textSize="13sp" />
            </LinearLayout>
            <LinearLayout android:layout_width="95dp" android:layout_height="105dp" android:layout_margin="8dp" android:background="@drawable/bg_home_card" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="36dp" android:layout_height="36dp" android:src="@drawable/ic_conquistas" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Conquistas" android:textColor="#FFFFFF" android:textSize="13sp" />
            </LinearLayout>
            <LinearLayout android:layout_width="95dp" android:layout_height="105dp" android:layout_margin="8dp" android:background="@drawable/bg_home_card" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="36dp" android:layout_height="36dp" android:src="@drawable/ic_estudar" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Estudar" android:textColor="#FFFFFF" android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Player de Áudio na Parte Inferior -->
    <LinearLayout
        android:id="@+id/llPlayer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:background="@drawable/bg_home_card"
        android:backgroundTint="#80000000"
        android:orientation="horizontal"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_circle_profile"
            android:contentDescription="Play"
            android:padding="14dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_play"
            app:tint="#FFFFFF" />

        <ImageButton
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_circle_profile"
            android:contentDescription="Pause"
            android:padding="14dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_pause"
            app:tint="#FFFFFF" />

        <ImageButton
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_circle_profile"
            android:contentDescription="Stop"
            android:padding="14dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_stop"
            app:tint="#FFFFFF" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>